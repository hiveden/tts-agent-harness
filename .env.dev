# =============================================================================
# TTS Agent Harness — Dev 环境配置
#
# 用法: cp .env.dev .env
# 所有服务从根 .env 读配置，不需要改代码。
# =============================================================================

# === Infrastructure (Docker compose 端口映射) ===
POSTGRES_PORT=55432
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
PREFECT_PORT=54200

# === Database ===
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:55432/harness

# === MinIO (S3 对象存储) ===
MINIO_ENDPOINT=localhost:59000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tts-harness
MINIO_SECURE=false

# === Prefect ===
PREFECT_API_URL=http://localhost:54200/api

# === Application Ports ===
API_PORT=8100
WEB_PORT=3010

# === WhisperX ===
WHISPERX_URL=http://localhost:7860
WHISPERX_MODE=local
# local  = 用 .venv 本地 Python 跑（ARM 原生，快）
# docker = 用 Docker 容器跑（生产 / CI）

# === Next.js (编译时注入) ===
NEXT_PUBLIC_API_URL=http://localhost:8100

# === Fish TTS API ===
FISH_TTS_KEY=your-key-here
# FISH_TTS_REFERENCE_ID=
# FISH_TTS_MODEL=s2-pro

# === Groq Whisper ASR（可选，云端替代本地 WhisperX）===
# GROQ_API_KEY=

# === 存储管理 ===
STORAGE_QUOTA_GB=5
STORAGE_TARGET_GB=4

# === 运行模式 ===
# TTS_USE_PREFECT=       # 空 = dev mode (in-process flow execution)
# HARNESS_API_TOKEN=     # 空 = 无鉴权 (dev mode)
LOG_LEVEL=info

# === 网络/代理 ===
# Fish API 需要代理（国内 DNS 污染 fish.audio）
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
# 防止 localhost 连接走代理
NO_PROXY=localhost,127.0.0.1
