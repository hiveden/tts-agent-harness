# Fish TTS API（必需）
FISH_TTS_KEY=your_fish_tts_api_key_here

# 声音模型（可选，不设则用 Fish 默认声音）
FISH_TTS_REFERENCE_ID=your_voice_reference_id_here

# TTS 参数（可选，默认从 .harness/config.json 读取）
# FISH_TTS_MODEL=s1
# TTS_SPEED=1.0

# Claude API（可选，默认用 Anthropic API）
# CLAUDE_API_URL=http://localhost:8317/v1/messages

# 代理（可选）
# HTTPS_PROXY=http://127.0.0.1:7890
