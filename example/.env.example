# Fish TTS API
FISH_TTS_KEY=your_fish_tts_api_key_here
FISH_TTS_REFERENCE_ID=your_voice_reference_id_here
FISH_TTS_MODEL=s1
TTS_SPEED=1.0

# Proxy (ClashX or similar)
# The harness uses HTTP CONNECT tunnel through this proxy for Fish TTS API calls
# Set to empty to disable proxy (modify p2-synth.js PROXY_HOST/PROXY_PORT)
