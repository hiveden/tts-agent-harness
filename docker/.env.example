#
# docker/.env.example — template for docker-compose.dev.yml
#
# Copy to docker/.env and tweak as needed. docker compose reads .env next to
# the compose file automatically.
#
# DO NOT commit real secrets.
#

# ---------- Postgres ----------
POSTGRES_USER=harness
POSTGRES_PASSWORD=harness
POSTGRES_DB=harness
POSTGRES_PORT=5432

# Connection URL used by alembic + FastAPI (host: localhost when running
# outside docker, postgres when running inside the compose network).
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:5432/harness

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=tts-harness

# S3 client config (used by server/core/storage.py in later waves)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tts-harness
S3_REGION=us-east-1

# ---------- Prefect ----------
PREFECT_PORT=4200
PREFECT_API_URL=http://localhost:4200/api
PREFECT_UI_URL=http://localhost:4200
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://harness:harness@postgres:5432/prefect

# ---------- Harness API auth (placeholder only — A1 does not implement auth) ----------
# See ADR-002 §10 Q1: shared token is the chosen scheme for W0.
# A9-API agent will wire this up; for now it is just a reserved env var.
HARNESS_API_TOKEN=change-me-in-prod

# ---------- Fish TTS (future A5-P2 use) ----------
# FISH_TTS_KEY=
# FISH_TTS_REFERENCE_ID=
# FISH_TTS_MODEL=s2-pro

# ---------- WhisperX svc (future A3 use) ----------
# WHISPERX_URL=http://whisperx-svc:7860
